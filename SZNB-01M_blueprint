  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "triple_button_2"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b2_triple
  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "long_button_2"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b2_long

  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "single_button_3"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b3_single
  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "double_button_3"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b3_double
  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "triple_button_3"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b3_triple
  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "long_button_3"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b3_long

  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "single_button_4"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b4_single
  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "double_button_4"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b4_double
  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "triple_button_4"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b4_triple
  - platform: mqtt
    topic: "{{ mqtt_topic }}"
    payload: "long_button_4"
    value_template: "{{ value_json.action if value_json.action is defined else '' }}"
    id: b4_long

condition: []

action:
  - choose:
      # --------------------
      # Button 1
      # --------------------
      - conditions:
          - condition: template
            value_template: "{{ trigger.id == 'b1_single' }}"
        sequence:
          - wait_for_trigger:
              - platform: mqtt
                topic: "{{ mqtt_topic }}"
                payload: "double_button_1"
                value_template: "{{ value_json.action if value_json.action is defined else '' }}"
                id: b1_double_followup
              - platform: mqtt
                topic: "{{ mqtt_topic }}"
                payload: "triple_button_1"
                value_template: "{{ value_json.action if value_json.action is defined else '' }}"
                id: b1_triple_followup
            timeout:
              milliseconds: !input multi_press_window_ms
            continue_on_timeout: true
          - choose:
              - conditions:
                  - condition: template
                    value_template: "{{ wait.completed and wait.trigger.id == 'b1_triple_followup' }}"
                sequence: !input button_1_triple
              - conditions:
                  - condition: template
                    value_template: "{{ wait.completed and wait.trigger.id == 'b1_double_followup' }}"
                sequence:
                  - wait_for_trigger:
                      - platform: mqtt
                        topic: "{{ mqtt_topic }}"
                        payload: "triple_button_1"
                        value_template: "{{ value_json.action if value_json.action is defined else '' }}"
                        id: b1_triple_after_double
                    timeout:
                      milliseconds: !input multi_press_window_ms
                    continue_on_timeout: true
                  - choose:
                      - conditions:
                          - condition: template
                            value_template: "{{ wait.completed and wait.trigger.id == 'b1_triple_after_double' }}"
                        sequence: !input button_1_triple
                    default: !input button_1_double
            default: !input button_1_single

      - conditions:
          - condition: template
            value_template: "{{ trigger.id == 'b1_double' }}"
        sequence:
          - wait_for_trigger:
              - platform: mqtt
                topic: "{{ mqtt_topic }}"
                payload: "triple_button_1"
                value_template: "{{ value_json.action if value_json.action is defined else '' }}"
                id: b1_triple_after_direct_double
            timeout:
              milliseconds: !input multi_press_window_ms
            continue_on_timeout: true
          - choose:
              - conditions:
                  - condition: template
                    value_template: "{{ wait.completed and wait.trigger.id == 'b1_triple_after_direct_double' }}"
                sequence: !input button_1_triple
            default: !input button_1_double

      - conditions:
          - condition: template
            value_template: "{{ trigger.id == 'b1_triple' }}"
        sequence: !input button_1_triple

      - conditions:
          - condition: template
            value_template: "{{ trigger.id == 'b1_long' }}"
        sequence: !input button_1_long

      # --------------------
