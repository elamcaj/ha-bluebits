blueprint:
  name: SONOFF Orb 4-In-1 (SNZB-01M) - Zigbee2MQTT Event Blueprint
  description: >
    Blueprint for the SONOFF Orb 4-In-1 Zigbee Smart Scene Button (SNZB-01M)
    using Zigbee2MQTT event entities.

    Button mapping:
      - Button 1 = top-left
      - Button 2 = top-right
      - Button 3 = bottom-left
      - Button 4 = bottom-right

    Supported actions:
      - single
      - double
      - triple
      - long

    Requires Zigbee2MQTT event entities enabled in:
      Zigbee2MQTT -> Settings -> Home Assistant integration

  domain: automation
  input:
    remote_event:
      name: SNZB-01M event entity
      description: Select the Zigbee2MQTT event entity for this remote, usually something like event.<device_name>_action
      selector:
        entity:
          domain: event

    button_1_single:
      name: Button 1 single press
      default: []
      selector:
        action: {}

    button_1_double:
      name: Button 1 double press
      default: []
      selector:
        action: {}

    button_1_triple:
      name: Button 1 triple press
      default: []
      selector:
        action: {}

    button_1_long:
      name: Button 1 long press
      default: []
      selector:
        action: {}

    button_2_single:
      name: Button 2 single press
      default: []
      selector:
        action: {}

    button_2_double:
      name: Button 2 double press
      default: []
      selector:
        action: {}

    button_2_triple:
      name: Button 2 triple press
      default: []
      selector:
        action: {}

    button_2_long:
      name: Button 2 long press
      default: []
      selector:
        action: {}

    button_3_single:
      name: Button 3 single press
      default: []
      selector:
        action: {}

    button_3_double:
      name: Button 3 double press
      default: []
      selector:
        action: {}

    button_3_triple:
      name: Button 3 triple press
      default: []
      selector:
        action: {}

    button_3_long:
      name: Button 3 long press
      default: []
      selector:
        action: {}

    button_4_single:
      name: Button 4 single press
      default: []
      selector:
        action: {}

    button_4_double:
      name: Button 4 double press
      default: []
      selector:
        action: {}

    button_4_triple:
      name: Button 4 triple press
      default: []
      selector:
        action: {}

    button_4_long:
      name: Button 4 long press
      default: []
      selector:
        action: {}

mode: queued
max_exceeded: silent

trigger:
  - platform: state
    entity_id: !input remote_event
    not_from:
      - unavailable
      - unknown
    not_to:
      - unavailable
      - unknown

variables:
  event_type: "{{ trigger.to_state.attributes.event_type | default('') }}"

condition:
  - condition: template
    value_template: "{{ event_type != '' }}"

action:
  - choose:
      - conditions:
          - condition: template
            value_template: "{{ event_type == 'single_button_1' }}"
        sequence: !input button_1_single

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'double_button_1' }}"
        sequence: !input button_1_double

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'triple_button_1' }}"
        sequence: !input button_1_triple

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'long_button_1' }}"
        sequence: !input button_1_long

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'single_button_2' }}"
        sequence: !input button_2_single

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'double_button_2' }}"
        sequence: !input button_2_double

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'triple_button_2' }}"
        sequence: !input button_2_triple

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'long_button_2' }}"
        sequence: !input button_2_long

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'single_button_3' }}"
        sequence: !input button_3_single

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'double_button_3' }}"
        sequence: !input button_3_double

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'triple_button_3' }}"
        sequence: !input button_3_triple

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'long_button_3' }}"
        sequence: !input button_3_long

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'single_button_4' }}"
        sequence: !input button_4_single

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'double_button_4' }}"
        sequence: !input button_4_double

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'triple_button_4' }}"
        sequence: !input button_4_triple

      - conditions:
          - condition: template
            value_template: "{{ event_type == 'long_button_4' }}"
        sequence: !input button_4_long
